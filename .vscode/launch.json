{
    "configurations": [
        {
            "name": "Python Debugger: Python File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}"
        },
        {
            "name": "Debug FastAPI",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8086",
                "--reload",
                "--timeout-keep-alive",
                "300",
                "--limit-concurrency",
                "1000"
            ],
            "jinja": true,
            "justMyCode": false,
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "Debug SRT Summary Script",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/long-srt-summary.py",
            "args": [
                "--input", "${workspaceFolder}/scripts/data/automat.srt",
                "--output-dir", "${workspaceFolder}/scripts/data/chunks",
                "--chunk-duration", "20"
            ],
            "justMyCode": false,
            "envFile": "${workspaceFolder}/.env",
            "console": "integratedTerminal"
        },
        {
            "name": "Debug SRT LONG Summary Script",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/long-srt-summary.py",
            "args": [
                "--input", "${workspaceFolder}/scripts/data/o_startegiach.srt",
                "--output-dir", "${workspaceFolder}/scripts/data/chunks",
                "--chunk-duration", "20"
            ],
            "justMyCode": false,
            "envFile": "${workspaceFolder}/.env",
            "console": "integratedTerminal"
        }
    ]
}